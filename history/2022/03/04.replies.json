    "client_msg_id": "ee6cd6ce-ebde-415e-8f2a-c6b62513afd6",
    "type": "message",
    "text": "This related to the \"<https://en.wikipedia.org/wiki/Curse_of_knowledge|the curse of knowledge>\", a cognitive bias where knowing something really well makes it more difficult for us to explain or teach it to someone else.",
    "user": "U018MHFH4HF",
    "ts": "1646413034.393839",
    "team": "T5TCAFTA9",
    "user_team": "T5TCAFTA9",
    "source_team": "T5TCAFTA9",
