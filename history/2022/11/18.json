    "upload": false,
    "user": "U018S42NMMM",
    "ts": "1668781119.937259",
    "blocks": [
      {
        "type": "rich_text",
        "block_id": "5qqM",
        "elements": [
          {
            "type": "rich_text_section",
            "elements": [
              {
                "type": "text",
                "text": "Not related to coding, but I have long been annoyed by how hard it was to discover and curate the best learning resources of the Web. Google/YouTube/Wikipedia do a terrible job of it and so do universities/coursera/edX by never linking out to the Web (eg: 3Blue1Brown or SmarterEveryDay). I wanted to collect links to amazing videos, interactive explorables, books, research papers and organize them by topics, formats, difficulty level etc.\n\nThis is what I made: "
              },
              {
                "type": "link",
                "url": "https://learnawesome.org/"
              },
              {
                "type": "text",
                "text": "\n\nSome highlights:\n"
              }
            ]
          },
          {
            "type": "rich_text_list",
            "elements": [
              {
                "type": "rich_text_section",
                "elements": [
                  {
                    "type": "text",
                    "text": "There is a custom topic taxonomy and a zoomable treemap."
                  }
                ]
              },
              {
                "type": "rich_text_section",
                "elements": [
                  {
                    "type": "text",
                    "text": "For books and papers, I make it easy to find them on SciHub/LibGen etc. When possible, resources like videos/wikis are embedded directly."
                  }
                ]
              },
              {
                "type": "rich_text_section",
                "elements": [
                  {
                    "type": "text",
                    "text": "I am planning aggregate reviews to help you select a resource among many available. So, under \"Sapiens\", you will see that Bill Gates recommends it highly."
                  }
                ]
              },
              {
                "type": "rich_text_section",
                "elements": [
                  {
                    "type": "text",
                    "text": "There is no server and no user accounts. Your bookmarks are kept in browser's localStorage only."
                  }
                ]
              },
              {
                "type": "rich_text_section",
                "elements": [
                  {
                    "type": "text",
                    "text": "Above all, this is a work-in-progress. Expect breakage."
                  }
                ]
              }
            ],
            "style": "bullet",
            "indent": 0,
            "border": 0
          },
          {
            "type": "rich_text_section",
            "elements": [
              {
                "type": "text",
                "text": "\nWould love to hear thoughts and feedback. "
              },
              {
                "type": "emoji",
                "name": "pray",
                "unicode": "1f64f"
              }
            ]
          }
        ]
      }
    ],
