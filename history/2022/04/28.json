        "thumb_height": 675,
        "video_html": "<video controls poster=\"https://pbs.twimg.com/ext_tw_video_thumb/1519811513149706247/pu/img/ovRpGR38kpS8VwwM.jpg\" width=\"1200\" height=\"675\"><source type=\"video/mp4\" src=\"https://video.twimg.com/ext_tw_video/1519811513149706247/pu/vid/1280x720/k75JNjz0JXSGqBLR.mp4?tag=12\"></video>",
