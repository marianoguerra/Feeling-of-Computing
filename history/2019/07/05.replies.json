  {
    "client_msg_id": "3a81fb73-131f-47fd-9772-53aae5e12cc8",
    "type": "message",
    "text": "What got me interested in term rewriting is its extreme modularity. Lots of small definitions that can be written in (almost) arbitrary order makes it suitable for embedding into prose, much like maths notation (see <http://khinsen.net/leibniz-examples/examples/leibniz-by-example.html>).",
    "user": "UJBAJNFLK",
