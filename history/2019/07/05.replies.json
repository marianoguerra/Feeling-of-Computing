  {
    "client_msg_id": "4c142e2e-e7e8-439e-9339-e7956d52f922",
    "type": "message",
    "text": "Maude was the language that convinced me there was real value in term rewriting. Others, like Stratego, helped me but Maude was a big inspiration. After I finish working on some pattern matching/substitution changes, I plan to investigate how to bring things like sorts into the picture.",
    "user": "UL7UQJ87R",
    "ts": "1562609186.130500",
    "team": "T5TCAFTA9",
    "user_team": "T5TCAFTA9",
    "source_team": "T5TCAFTA9",
