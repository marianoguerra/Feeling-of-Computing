      "image_72": "https://secure.gravatar.com/avatar/65a4914487efb21d1cb5dd1f4130b343.jpg?s=72&d=https%3A%2F%2Fa.slack-edge.com%2Fdf10d%2Fimg%2Favatars%2Fava_0019-72.png",
