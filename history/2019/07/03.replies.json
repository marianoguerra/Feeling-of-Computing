  {
    "client_msg_id": "ca7ec255-abd9-4bdf-965d-ce73c97bd446",
    "type": "message",
    "text": "To me BESAT felt like a hack to get around misestimating low probability events with online sampling in one particular case.  Undercuts generality and formal simplicity of the method?",
    "user": "UKLV35EEM",
    "ts": "1563411918.246800",
