  },
  {
    "client_msg_id": "de6d446a-b154-47b2-ae69-a33b27415506",
    "type": "message",
    "text": "On this topic, I like the way Ortega frames the issues here and I'll aim to implement something along these lines for interactions with the environment:\n<http://www.adaptiveagents.org/bayesian_causal_induction>\n<http://www.adaptiveagents.org/causality>",
    "user": "UL3FQ4PHB",
