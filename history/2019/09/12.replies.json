  },
  {
    "client_msg_id": "085affe4-5d2c-46ea-b30e-4c83dbf0d1a7",
    "type": "message",
    "text": "The animation tools in Adobe Animate are beloved by animators. Very easy to use, and highly evolved after 20+ years. Animation tools take an incredibly long time to perfect. People use keyboard shortcuts, and need fast response.",
    "user": "UEQ6M68H0",
    "ts": "1568533202.002200",
