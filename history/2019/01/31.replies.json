      "image_72": "https://secure.gravatar.com/avatar/d48812709bdc0ff86746b7fbe56b0f13.jpg?s=72&d=https%3A%2F%2Fa.slack-edge.com%2Fdf10d%2Fimg%2Favatars%2Fava_0010-72.png",
