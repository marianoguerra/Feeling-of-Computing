  {
    "client_msg_id": "fb1937ea-3cd1-45c1-89c3-9a5efd2bec00",
    "type": "message",
    "text": "We have machines that turn high level requirements into working software today--they're called programming generalists and they are A) in extremely high demand, B) on the right side of the human talent bell curve, C) take ~5-7 years to train.  Why do we think we can create software to do something that by all accounts is extremely hard to do?",
    "user": "UJKC8B0QN",
    "ts": "1559057917.145600",
    "team": "T5TCAFTA9",
    "user_team": "T5TCAFTA9",
    "source_team": "T5TCAFTA9",
    "user_profile": {
