  {
    "client_msg_id": "de35276a-a0e0-4412-827f-7caecf336c9f",
    "type": "message",
    "text": "I think we should distinguish between a set of applications that test the coverage of a PL and one that tests programming skills. Is the goal the former or the latter? If it's the former, I'd prefer a larger set of low-complexity applications.",
    "user": "UEP7RL0HX",
    "ts": "1565850225.069500",
    "team": "T5TCAFTA9",
    "user_team": "T5TCAFTA9",
    "source_team": "T5TCAFTA9",
    "user_profile": {
