  },
  {
    "client_msg_id": "6693d345-4a4e-444d-8bd3-1ac2e685511e",
    "type": "message",
    "text": "yes, definitely.  I did clojure for a time, then noticed java pick up streams, then kotlin taking it a little further in the FP direction but still similar enough to be popular.",
    "user": "UM1HH60GN",
    "ts": "1565194206.084600",
    "team": "T5TCAFTA9",
    "user_team": "T5TCAFTA9",
    "source_team": "T5TCAFTA9",
