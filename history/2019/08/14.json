  {
    "client_msg_id": "0da99ed1-9317-47bf-ad4f-bc7950a1fa7e",
    "type": "message",
    "text": "I didn't like some of the 7GUIs that weren't real-world enough",
    "user": "UEP7RL0HX",
    "ts": "1565807599.041800",
    "team": "T5TCAFTA9",
    "user_team": "T5TCAFTA9",
    "source_team": "T5TCAFTA9",
