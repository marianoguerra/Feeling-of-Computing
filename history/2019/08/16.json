  {
    "client_msg_id": "1c742c4a-d935-425c-9a6c-33deb12a222a",
    "type": "message",
    "text": "For this example, you could probably have the principle \"if the user has a question about the state of the world, then there should be a means to immediately access this state from any point in their app\".",
    "user": "UCGAK10LS",
    "ts": "1565925390.085200",
    "team": "T5TCAFTA9",
    "user_team": "T5TCAFTA9",
    "source_team": "T5TCAFTA9",
