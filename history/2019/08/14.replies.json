  },
  {
    "client_msg_id": "160415bc-fd7b-4bb5-8b8f-37c4ec0d94d2",
    "type": "message",
    "text": "Perhaps we need to better define what we mean by \"end-user programming language\". Is it low code? No code? Is it a full PL with a quick learning curve? Once we do that, we might get a better grip on the minimal application set.",
    "user": "UEP7RL0HX",
    "ts": "1565851490.079600",
    "team": "T5TCAFTA9",
    "user_team": "T5TCAFTA9",
