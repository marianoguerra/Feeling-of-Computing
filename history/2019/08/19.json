  {
    "client_msg_id": "abbbd40a-4072-49e2-8406-b86759cda59e",
    "type": "message",
    "text": "I weakly believe that if we had truly empowered individuals, communities would just work right by default. There may not be any more work to do!",
    "user": "UCUSW7WVD",
    "ts": "1566239151.157100",
    "team": "T5TCAFTA9",
    "user_team": "T5TCAFTA9",
