  {
    "client_msg_id": "6b7700ed-bacd-4d0c-ac4f-76e367840f31",
    "type": "message",
    "text": "as you can see, I agree with both of you :smile:",
    "user": "UE6EFEPTQ",
    "ts": "1566240127.158100",
    "team": "T5TCAFTA9",
    "user_team": "T5TCAFTA9",
    "source_team": "T5TCAFTA9",
    "user_profile": {
      "avatar_hash": "8073c43d5d8d",
      "image_72": "https://avatars.slack-edge.com/2018-12-18/508431502471_8073c43d5d8dd3d3b4b2_72.jpg",
      "first_name": "Duncan",
      "real_name": "Duncan Cragg",
      "display_name": "Duncan Cragg",
      "team": "T5TCAFTA9",
      "name": "fp",
      "is_restricted": false,
      "is_ultra_restricted": false
    },
    "reactions": [
      {
