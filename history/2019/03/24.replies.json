  {
    "client_msg_id": "663226ec-c9c6-4428-9a0a-2f478b19b687",
    "type": "message",
    "text": "Oops, I forgot to post my favourite computing paper: “Folk Computing: Revisiting Oral Tradition as\na Scaffold for Co-Present Communities”. In which a team from MIT take a couple of hundred Sega Dreamcast VMUs, spread them amongst school kids, and teach them how to make and share little programs. <https://llk.media.mit.edu/papers/archive/folk-computing.pdf>",
    "user": "UFV8P4472",
    "ts": "1553497680.082900",
    "team": "T5TCAFTA9",
    "user_team": "T5TCAFTA9",
    "source_team": "T5TCAFTA9",
    "user_profile": {
      "avatar_hash": "ge9db5e1065d",
      "image_72": "https://secure.gravatar.com/avatar/ce9db5e1065df82be338b2d831201fc6.jpg?s=72&d=https%3A%2F%2Fa.slack-edge.com%2Fdf10d%2Fimg%2Favatars%2Fava_0002-72.png",
      "first_name": "",
      "real_name": "Yoz Grahame",
      "display_name": "yoz",
      "team": "T5TCAFTA9",
      "name": "yoz",
      "is_restricted": false,
      "is_ultra_restricted": false
    },
    "thread_ts": "1553462373.080400",
