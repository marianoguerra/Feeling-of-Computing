      "image_72": "https://avatars.slack-edge.com/2019-03-27/582042668721_465336060ae83dc74288_72.jpg",
      "first_name": "Wouter",
      "real_name": "Wouter van Oortmerssen",
      "display_name": "Wouter",
      "team": "T5TCAFTA9",
      "name": "aardappel",
      "is_restricted": false,
      "is_ultra_restricted": false
    },
