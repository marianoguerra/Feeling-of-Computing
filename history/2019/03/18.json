  {
    "client_msg_id": "e206849e-7168-473c-ab1d-c7021646ccf6",
    "type": "message",
    "text": "Great work on your thesis. I think that JS itself is the problem though; you can't make a sturdy structure on a foundation of mud, and JS being a copy of ActionScript 2 from so many years ago, has some intrinsic flaws that make it a quite poor choice for the main language of the internet, however that is the history of how it came out.",
    "user": "UEQ6M68H0",
    "ts": "1552891865.051800",
    "team": "T5TCAFTA9",
    "user_team": "T5TCAFTA9",
    "source_team": "T5TCAFTA9",
    "user_profile": {
      "avatar_hash": "326328f75c3f",
      "image_72": "https://avatars.slack-edge.com/2019-02-05/542651515888_326328f75c3f2a08544c_72.jpg",
      "first_name": "Edward",
      "real_name": "Edward de Jong",
      "display_name": "Edward de Jong / Beads Project",
      "team": "T5TCAFTA9",
      "name": "magicmouse94937",
      "is_restricted": false,
      "is_ultra_restricted": false
    },
    "thread_ts": "1552859175.050000",
