  {
    "user": "UJBAJNFLK",
    "type": "message",
    "ts": "1748605135.726209",
    "client_msg_id": "e4b32259-0f6a-4d5c-a5e4-dc5c32ad32ca",
    "text": "This is using the browser in the same way that many people, including myself, use Emacs: as a flexible user interface to lots of other programs. A thin client.\n\nIn the abstract, I really like this. In practice, I find it too risky on today's browser oligarchy. In particular for a terminal. I see the terminal as the lowest-level UI on my computer. When everything else fails, for whatever reason, I still have the terminal. Making the browser a dependency of the terminal feels very wrong.\n\nYes, I know, using a Web terminal doesn't take the native terminal away. But it still feels as if an earthquake had messed up the software stack.",
    "team": "T5TCAFTA9",
    "thread_ts": "1748533162.167309",
    "parent_user_id": "U06MJU6LBN3",
    "blocks": [
      {
        "type": "rich_text",
        "block_id": "XIlDT",
        "elements": [
          {
            "type": "rich_text_section",
            "elements": [
              {
                "type": "text",
                "text": "This is using the browser in the same way that many people, including myself, use Emacs: as a flexible user interface to lots of other programs. A thin client.\n\nIn the abstract, I really like this. In practice, I find it too risky on today's browser oligarchy. In particular for a terminal. I see the terminal as the lowest-level UI on my computer. When everything else fails, for whatever reason, I still have the terminal. Making the browser a dependency of the terminal feels very wrong.\n\nYes, I know, using a Web terminal doesn't take the native terminal away. But it still feels as if an earthquake had messed up the software stack."
              }
            ]
          }
        ]
      }
    ],
    "reactions": [
      {
        "name": "+1",
        "users": [
          "U06MJU6LBN3"
        ],
        "count": 1
      }
    ],
    "channel_name": "share-your-work",
