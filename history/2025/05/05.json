  {
    "user": "UKM22EFEG",
    "type": "message",
    "ts": "1746483329.425349",
    "client_msg_id": "2cdcc111-b6f9-4da4-8086-1c813f55ec51",
    "text": "Hey all! Excited to share a new project some of us (Elliot Boschewitz, Christian Clampitt, Adam Menges, and myself) have been hacking on, Stitch: <https://stitchdesign.app/>\n\nWe’re ready to add people in mass to the TestFlight. It’s an *open source* version of a visual programming environment, similar to Origami or Quartz Composer.\n\nIn addition to being able to build anything those two can, it also supports AR, CoreML, and native 3D support. As well as being built in SwiftUI, so it runs on basically any Apple device and is easy to hack on and improve.\n\nIt’s open source, and we welcome new contributions! <https://github.com/StitchDesign/Stitch>\n\nSign up for the Test Flight here: <https://docs.google.com/forms/d/e/1FAIpQLSc4ImI4KpHJNgidj2g_KgAbKqYgt9R1txDl-tWKQxFDKpJkcQ/viewform>",
    "team": "T5TCAFTA9",
    "thread_ts": "1746483329.425349",
    "reply_count": 2,
    "reply_users_count": 2,
    "latest_reply": "1746489815.016829",
    "reply_users": [
      "UC2A2ARPT",
      "UKM22EFEG"
    ],
    "is_locked": false,
    "subscribed": false,
    "attachments": [
      {
        "image_url": "https://framerusercontent.com/images/2DSMogkS742xn2BHdeGMFsdi5Y.png",
        "image_width": 2213,
        "image_height": 1162,
        "image_bytes": 42075,
        "from_url": "https://stitchdesign.app/",
        "service_icon": "https://framerusercontent.com/images/6bgeVOJh5rqZVSt6UTdJze3OyY.png",
        "id": 1,
        "original_url": "https://stitchdesign.app/",
        "fallback": "Stitch",
        "text": "UI Prototyping for Designers",
        "title": "Stitch",
        "title_link": "https://stitchdesign.app/",
        "service_name": "stitchdesign.app"
      }
    ],
    "blocks": [
      {
        "type": "rich_text",
        "block_id": "VWhv1",
        "elements": [
          {
            "type": "rich_text_section",
            "elements": [
              {
                "type": "text",
                "text": "Hey all! Excited to share a new project some of us (Elliot Boschewitz, Christian Clampitt, Adam Menges, and myself) have been hacking on, Stitch: "
              },
              {
                "type": "link",
                "url": "https://stitchdesign.app/"
              },
              {
                "type": "text",
                "text": "\n\nWe’re ready to add people in mass to the TestFlight. It’s an "
              },
              {
                "type": "text",
                "text": "open source",
                "style": {
                  "bold": true
                }
              },
              {
                "type": "text",
                "text": " version of a visual programming environment, similar to Origami or Quartz Composer.\n\nIn addition to being able to build anything those two can, it also supports AR, CoreML, and native 3D support. As well as being built in SwiftUI, so it runs on basically any Apple device and is easy to hack on and improve.\n\nIt’s open source, and we welcome new contributions! "
              },
              {
                "type": "link",
                "url": "https://github.com/StitchDesign/Stitch"
              },
              {
                "type": "text",
                "text": "\n\nSign up for the Test Flight here: "
              },
              {
                "type": "link",
                "url": "https://docs.google.com/forms/d/e/1FAIpQLSc4ImI4KpHJNgidj2g_KgAbKqYgt9R1txDl-tWKQxFDKpJkcQ/viewform"
              }
            ]
          }
        ]
      }
    ],
