    "type": "message",
    "ts": "1747807995.691919",
    "client_msg_id": "b6168f60-f2b2-4a6f-95da-e027e068098e",
    "text": "<@UJBAJNFLK> Interesting, never seen this format before. Seems like it is fully P2P / every client has its own copy of the state, rather than Client-Sever?",
    "team": "T5TCAFTA9",
    "thread_ts": "1747767270.134319",
    "parent_user_id": "U08R8AQ7WKX",
    "blocks": [
      {
        "type": "rich_text",
        "block_id": "NscfE",
        "elements": [
          {
            "type": "rich_text_section",
            "elements": [
              {
                "type": "user",
                "user_id": "UJBAJNFLK"
              },
              {
                "type": "text",
                "text": " Interesting, never seen this format before. Seems like it is fully P2P / every client has its own copy of the state, rather than Client-Sever?"
              }
            ]
          }
        ]
      }
    ],
    "channel_name": "share-your-work",
    "channel_id": "CCL5VVBAN"
  },
  {
    "user": "UJBAJNFLK",
    "type": "message",
    "ts": "1747811617.457549",
    "edited": {
      "user": "UJBAJNFLK",
      "ts": "1747819423.000000"
    },
    "client_msg_id": "aa7feb8e-2440-4f0d-8299-aa0e0dbfca89",
    "text": "Yes, every client keeps a copy of the state. State changes are communicated by encrypted e-mail or XMPP messages. This is why the state is effectively shared by the members of a chat group, which also runs on encrypted e-mail messages/XMPP behind the scenes.",
    "team": "T5TCAFTA9",
    "thread_ts": "1747767270.134319",
    "parent_user_id": "U08R8AQ7WKX",
    "blocks": [
