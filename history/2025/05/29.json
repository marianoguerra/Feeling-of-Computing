  {
    "user": "U06SS0DHZD1",
    "type": "message",
    "ts": "1748507108.516219",
    "client_msg_id": "5e0d8fd0-cd0f-4cb7-8dfc-54cc8b1febc9",
    "text": "It's called graphical neutral network. They attach feature vectors to vertices and/or edges and can be used to build all sorts of graph processing primitives. They can use transformers under the hood so I guess that somebody already had to merge them with LLMs. Mixed modality text/graph data is possible. I was just wondering if there are any APIs that allow graphs as input or output (similar to how some LLMs allow audio or images).",
    "team": "T5TCAFTA9",
    "thread_ts": "1748503588.933639",
    "parent_user_id": "U0123H7JRDM",
    "blocks": [
      {
        "type": "rich_text",
        "block_id": "yrTOM",
        "elements": [
          {
            "type": "rich_text_section",
            "elements": [
              {
                "type": "text",
                "text": "It's called graphical neutral network. They attach feature vectors to vertices and/or edges and can be used to build all sorts of graph processing primitives. They can use transformers under the hood so I guess that somebody already had to merge them with LLMs. Mixed modality text/graph data is possible. I was just wondering if there are any APIs that allow graphs as input or output (similar to how some LLMs allow audio or images)."
              }
            ]
          }
        ]
      }
    ],
    "channel_name": "share-your-work",
    "channel_id": "CCL5VVBAN"
  },
