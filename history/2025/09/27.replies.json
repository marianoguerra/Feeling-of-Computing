    "type": "message",
    "ts": "1759010529.216569",
    "client_msg_id": "fd3785f9-f168-4a96-a0e5-d968359fcd82",
    "text": "Nice listen! You mentioned Orca, which isn't really an esolang in that it's made for practical use and has a large community of practice around it, despite looking a lot like befunge. I think Devine had seen befunge before, but had forgotten about it and hadn't consciously used it as a reference. I think that supports Lu's point that esotericness is relative.",
    "team": "T5TCAFTA9",
    "thread_ts": "1758948679.318799",
    "parent_user_id": "UC2A2ARPT",
    "blocks": [
      {
        "type": "rich_text",
        "block_id": "Li4vA",
        "elements": [
          {
            "type": "rich_text_section",
            "elements": [
              {
                "type": "text",
                "text": "Nice listen! You mentioned Orca, which isn't really an esolang in that it's made for practical use and has a large community of practice around it, despite looking a lot like befunge. I think Devine had seen befunge before, but had forgotten about it and hadn't consciously used it as a reference. I think that supports Lu's point that esotericness is relative."
              }
            ]
          }
        ]
      }
    ],
