      {
        "image_url": "https://static.observableusercontent.com/thumbnail/875cfc2e9a274ba40e828c752f1abe3ccff0cf52e630ad4a62cacd94ec38e769.jpg",
        "image_width": 640,
        "image_height": 400,
        "image_bytes": 49947,
        "from_url": "https://observablehq.com/@tomlarkworthy/robocoop",
        "service_icon": "https://static.observablehq.com/favicon-512.0667824687f99c942a02e06e2db1a060911da0bf3606671676a255b1cf97b4fe.png",
        "ts": 1699396849,
        "id": 1,
        "original_url": "https://observablehq.com/@tomlarkworthy/robocoop",
        "fallback": "Observable: Roboco-op: a computational blackboard for efficient human/AI collaboration",
        "text": "Robocoop is a different approach to building an AI coding assistant. In Robocoop, the LLM context is paired with code so it can be hand edited, imported, deleted and forked at any point during development. Its like Chat + Computational Notebook + RAG all wrapped into one. Roboco-op blends <http://Observablehq.com|Observablehq.com>'s reactive notebooks with an open source userspace AI coding assistant. Observable notebooks are a unique coding environment because the code development and runtime state are mixed together. This means Ro",
        "title": "Roboco-op: a computational blackboard for efficient human/AI collaboration",
        "title_link": "https://observablehq.com/@tomlarkworthy/robocoop",
        "service_name": "Observable"
      },
      {
        "image_url": "https://static.observableusercontent.com/thumbnail/f7e5be7747535b6e526cfd42de66b48a4f3a3b01c4be740eade7ae964805f284.jpg",
        "image_width": 640,
        "image_height": 400,
        "image_bytes": 32153,
        "from_url": "https://observablehq.com/@tomlarkworthy/observablejs-toolchain",
        "service_icon": "https://static.observablehq.com/favicon-512.0667824687f99c942a02e06e2db1a060911da0bf3606671676a255b1cf97b4fe.png",
        "ts": 1726549488,
        "id": 2,
        "original_url": "https://observablehq.com/@tomlarkworthy/observablejs-toolchain",
        "fallback": "Observable: Bidirectional Observable JS  Runtime Toolchain",
        "text": "Compilation, source to runtime variable(s) Compilation takes notebook source cells written in `Observable Javascript` and turns them into reactive variables for execution in the `Observable Runtime`. A cell is usually compiled to one runtime variable, however, mutable variables are more complicated and are represented as three runtime variables. ObservableHQ does the compilation process as part of the hosted notebook experience but in this notebook we provide a way to do it in userspace. Decompilation, Runt",
        "title": "Bidirectional Observable JS  Runtime Toolchain",
        "title_link": "https://observablehq.com/@tomlarkworthy/observablejs-toolchain",
        "service_name": "Observable"
      }
    ],
