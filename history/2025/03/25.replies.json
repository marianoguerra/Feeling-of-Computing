            "elements": [
              {
                "type": "text",
                "text": "I have been thinking recently that it’s probably time for a more elaborate, decorative style of UI to have its turn.\n\nI’m working on an app atm, so I might try something there."
              }
            ]
          }
        ]
      }
    ],
    "channel_name": "present-company",
    "channel_id": "C01932BJGE8"
