  {
    "client_msg_id": "62677a30-94f8-42ec-9337-f06c7a23dae1",
    "type": "message",
    "text": "I used a trick for a few years that would teach `ctags` about wikiwords so I could refer to large comments on specific design decisions by name in arbitrary places.",
    "user": "UCUSW7WVD",
    "ts": "1544135713.015600",
