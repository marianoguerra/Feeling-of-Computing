  {
    "client_msg_id": "7e1bf8d8-cf48-492c-864d-c100f4a5fe6c",
    "type": "message",
    "text": "Well, I still want to keep it as documentation first. Make it undestandable for humans first.\n\nI'm fine with manual assistance of translating plain text statement into formula.",
    "user": "UCKRZS3DZ",
    "ts": "1542266008.086500",
    "team": "T5TCAFTA9",
    "user_team": "T5TCAFTA9",
