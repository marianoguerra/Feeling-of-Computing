    "attachments": [
      {
        "from_url": "https://observablehq.com/@tomlarkworthy/parameteric-svg",
        "ts": 1775477930,
        "image_url": "https://static.observableusercontent.com/thumbnail/584d7c53f16b4a4458d697717efda6c0da7b8f259511f3004237c97f2d80b566.jpg",
        "image_width": 640,
        "image_height": 400,
        "image_bytes": 8215,
        "service_icon": "https://static.observablehq.com/favicon-512.0667824687f99c942a02e06e2db1a060911da0bf3606671676a255b1cf97b4fe.png",
        "id": 1,
        "original_url": "https://observablehq.com/@tomlarkworthy/parameteric-svg",
        "fallback": "Observable: Interactive Parametric SVG via Numerical Solving",
        "text": "You write the forward direction: parameters → shape + anchors. The numerical solver figures out the backward direction automatically: dragging anchors → parameter updates → shape redraws. Try the robot arm below — drag any joint or the end effector. Shift+click to lock an anchor in place. On a touchscreen, use multi-touch to drag several anchors simultaneously. How It Works You only write the forward mapping: a cell that takes parameters (wired up as \\`viewof\\` range inputs) and returns SVG with \\`anchor()\\",
        "title": "Interactive Parametric SVG via Numerical Solving",
        "title_link": "https://observablehq.com/@tomlarkworthy/parameteric-svg",
        "service_name": "Observable"
      }
