  {
    "user": "UJBAJNFLK",
    "type": "message",
    "ts": "1714800484.051499",
    "client_msg_id": "808a1005-21b3-41bc-bfcf-68a2fa7937e3",
    "text": "I see the link between these converging directions of thought in postmodernism. Modernism is the quest for dominance of humanity over nature through rationality. Postmodernism is the critique of dominance and control. The conflict between the two is the cause of the meaning crisis. What's missing so far is the way out: critique shows problems, but offers no solutions. In a way, this forum is about postmodernism applied to information technology.",
    "team": "T5TCAFTA9",
    "thread_ts": "1714490368.887299",
    "parent_user_id": "UJBAJNFLK",
    "blocks": [
      {
        "type": "rich_text",
        "block_id": "cK7Zl",
        "elements": [
          {
            "type": "rich_text_section",
            "elements": [
              {
                "type": "text",
                "text": "I see the link between these converging directions of thought in postmodernism. Modernism is the quest for dominance of humanity over nature through rationality. Postmodernism is the critique of dominance and control. The conflict between the two is the cause of the meaning crisis. What's missing so far is the way out: critique shows problems, but offers no solutions. In a way, this forum is about postmodernism applied to information technology."
              }
            ]
          }
        ]
      }
    ],
