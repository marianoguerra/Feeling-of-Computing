  {
    "user": "U5STGTB3J",
    "type": "message",
    "ts": "1712832197.937769",
    "client_msg_id": "70d249d0-b741-4fd4-96be-139e1b0fd99a",
    "text": "&gt; “simplicity\" is a relative term - it’s in the eyes of the beholder\nYeah, that’s not a widely spread belief in software circles, yet. My essay is going to address that. And surely the papers I listed all explicitly or implicitly assume that simplicity can be objectively defined. Curiously, most of them just assume but don’t attempt to define it. Hickey gets bonus points, because he actually does.",
    "team": "T5TCAFTA9",
    "thread_ts": "1712753544.771459",
    "parent_user_id": "U5STGTB3J",
    "blocks": [
      {
        "type": "rich_text",
        "block_id": "3giPv",
        "elements": [
          {
            "type": "rich_text_quote",
            "elements": [
              {
                "type": "text",
                "text": "“simplicity\" is a relative term - it’s in the eyes of the beholder"
              }
            ]
          },
          {
            "type": "rich_text_section",
            "elements": [
              {
                "type": "text",
                "text": "\nYeah, that’s not a widely spread belief in software circles, yet. My essay is going to address that. And surely the papers I listed all explicitly or implicitly assume that simplicity can be objectively defined. Curiously, most of them just assume but don’t attempt to define it. Hickey gets bonus points, because he actually does."
              }
            ]
          }
        ]
      }
    ],
    "channel_name": "linking-together",
    "channel_id": "C5U3SEW6A"
  },
