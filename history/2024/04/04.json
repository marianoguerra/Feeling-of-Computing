  {
    "user": "U04SAJZ155H",
    "type": "message",
    "ts": "1712269067.586549",
    "client_msg_id": "a5c3f592-c98a-4a12-a2d1-5b1f8c1b5861",
    "text": "That's the only web stack I would actually like to build on. I've been wanting something like that for many years already, but have found out that Wasm is worse than JS whenever interacting with the outside world is a major requirement, because it's confined to its private linear memory. It seems to be better now with the GC extension.",
    "team": "T5TCAFTA9",
    "thread_ts": "1712265191.536479",
    "parent_user_id": "UC2A2ARPT",
    "blocks": [
      {
        "type": "rich_text",
        "block_id": "oCwc8",
        "elements": [
          {
            "type": "rich_text_section",
            "elements": [
              {
                "type": "text",
                "text": "That's the only web stack I would actually like to build on. I've been wanting something like that for many years already, but have found out that Wasm is worse than JS whenever interacting with the outside world is a major requirement, because it's confined to its private linear memory. It seems to be better now with the GC extension."
              }
            ]
          }
        ]
      }
    ],
    "channel_name": "linking-together",
    "channel_id": "C5U3SEW6A"
  },
  {
    "user": "UBKNXPBAB",
    "type": "message",
    "ts": "1712269828.546489",
    "client_msg_id": "f8d6c6f3-9f87-488a-a91d-a421050fec29",
    "text": "Naturally I see the benefits. But I’ll highlight that this proposal entirely abandons the DOM as an open, addressable substrate, so, you know, no more browser extensions or web scraping or anything like that. (The DOM is certainly an imperfect substrate, but it’s kinda amazing that it’s stuck around this long and still functions as an entry point for malleability.)",
    "team": "T5TCAFTA9",
    "thread_ts": "1712265191.536479",
    "parent_user_id": "UC2A2ARPT",
    "blocks": [
      {
        "type": "rich_text",
        "block_id": "AyNYS",
        "elements": [
          {
            "type": "rich_text_section",
            "elements": [
              {
                "type": "text",
                "text": "Naturally I see the benefits. But I’ll highlight that this proposal entirely abandons the DOM as an open, addressable substrate, so, you know, no more browser extensions or web scraping or anything like that. (The DOM is certainly an imperfect substrate, but it’s kinda amazing that it’s stuck around this long and still functions as an entry point for malleability.)"
              }
            ]
          }
        ]
      }
    ],
