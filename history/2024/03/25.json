    "client_msg_id": "5ac3cb6f-1a3d-4c76-9ee4-9856e2f201d3",
    "text": "I think the main thing wrong with Dynamicland _is_ its core, local-only, in-person philosophy! I obviously get the whole \"handling real objects and interacting in person with people right next to you\" idea, but to specifically cut out internet-based XR* from the discussion (and derived from that, or on top of that, having no normal internet presence and not being more open to non-in-person discussion of the ideas) seems very narrow-minded.\n\n(* AR and VR)",
    "team": "T5TCAFTA9",
    "thread_ts": "1711276617.466159",
    "parent_user_id": "UE6EFEPTQ",
    "blocks": [
      {
        "type": "rich_text",
        "block_id": "mUzqg",
        "elements": [
          {
            "type": "rich_text_section",
            "elements": [
              {
                "type": "text",
                "text": "I think the main thing wrong with Dynamicland "
              },
              {
                "type": "text",
                "text": "is",
                "style": {
                  "italic": true
                }
              },
              {
                "type": "text",
                "text": " its core, local-only, in-person philosophy! I obviously get the whole \"handling real objects and interacting in person with people right next to you\" idea, but to specifically cut out internet-based XR* from the discussion (and derived from that, or on top of that, having no normal internet presence and not being more open to non-in-person discussion of the ideas) seems very narrow-minded.\n\n(* AR and VR)"
              }
            ]
          }
        ]
      }
    ],
    "channel_name": "thinking-together",
    "channel_id": "C5T9GPWFL"
  },
