[
  {
    "user": "UJBAJNFLK",
    "type": "message",
    "ts": "1711349995.406479",
    "client_msg_id": "b38f932a-9fa3-4644-a3ec-b30a6bbb5c07",
    "text": "Strong agree with <@U05SU27S1M2> that we need to experiment with new forms of collaboration. Open Source was a first step out of the industrial-capitalist mindset. We need to take more steps.\n\nFor the project list, that means thinking harder about what should and what should not be in it. Only projects from people active in our community? Only Open Source projects? I'd tone down the latter to \"only projects that we can learn from\", which requires less openness than Open Source.",
    "team": "T5TCAFTA9",
    "thread_ts": "1711276617.466159",
    "parent_user_id": "UE6EFEPTQ",
    "blocks": [
      {
        "type": "rich_text",
        "block_id": "T574y",
        "elements": [
          {
            "type": "rich_text_section",
            "elements": [
              {
                "type": "text",
                "text": "Strong agree with "
              },
              {
                "type": "user",
                "user_id": "U05SU27S1M2"
              },
              {
                "type": "text",
                "text": " that we need to experiment with new forms of collaboration. Open Source was a first step out of the industrial-capitalist mindset. We need to take more steps.\n\nFor the project list, that means thinking harder about what should and what should not be in it. Only projects from people active in our community? Only Open Source projects? I'd tone down the latter to \"only projects that we can learn from\", which requires less openness than Open Source."
              }
            ]
          }
        ]
      }
    ],
