    "client_msg_id": "1f506bcc-082e-4328-aa1d-c8746074eaf4",
    "text": "For those of you interested in Christopher Alexander’s work: The *<https://christopher-alexander-ces-archive.org/|Christopher Alexander &amp; Center for Environmental Structure Archive>* is live. Here's an excerpt from Maggie Moore Alexander's announcement:\n&gt; This new website gives access to 50+ years of work by Alexander and colleagues at CES. The goal of this continuing endeavor is to share the work with all who wish to build and repair living environments in which people thrive.\n&gt; In total, the Archive includes some 29,000 items. About 50% of them have been catalogued to date and are listed on the website. Around 6000 items have been digitized and are now available from the website as downloads. As funding allows, we will work toward making the whole collection available.\n<https://christopher-alexander-ces-archive.org/>",
    "team": "T5TCAFTA9",
    "blocks": [
      {
        "type": "rich_text",
        "block_id": "wXMAT",
        "elements": [
          {
            "type": "rich_text_section",
            "elements": [
              {
                "type": "text",
                "text": "For those of you interested in Christopher Alexander’s work: The "
              },
              {
                "type": "link",
                "url": "https://christopher-alexander-ces-archive.org/",
                "text": "Christopher Alexander & Center for Environmental Structure Archive",
                "style": {
                  "bold": true
                }
              },
              {
                "type": "text",
                "text": " is live. Here's an excerpt from Maggie Moore Alexander's announcement:\n"
              }
            ]
          },
          {
            "type": "rich_text_quote",
            "elements": [
              {
                "type": "text",
                "text": "This new website gives access to 50+ years of work by Alexander and colleagues at CES. The goal of this continuing endeavor is to share the work with all who wish to build and repair living environments in which people thrive.\nIn total, the Archive includes some 29,000 items. About 50% of them have been catalogued to date and are listed on the website. Around 6000 items have been digitized and are now available from the website as downloads. As funding allows, we will work toward making the whole collection available."
              }
            ]
          },
          {
            "type": "rich_text_section",
            "elements": [
              {
                "type": "link",
                "url": "https://christopher-alexander-ces-archive.org/"
              }
            ]
          }
        ]
      }
