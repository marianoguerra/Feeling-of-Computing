    "client_msg_id": "0b221c3f-6038-4874-ae21-66cb7577513f",
    "text": "FWIW, my reaction to something mentioned in the latest FoC podcast (<https://futureofcoding.org/episodes/073>):\n\nComputer Science isn’t about _programming_. Computer Science is about mapping computational thinking into the digital domain and discovering problems in an ad-hoc manner, then fixing the problems to make the mapping work on reprogrammable electronic machines.\n\n<https://programmingsimplicity.substack.com/p/computational-thinking-run-amok?r=1egdky>",
    "team": "T5TCAFTA9",
    "blocks": [
      {
        "type": "rich_text",
        "block_id": "ATTH9",
        "elements": [
          {
            "type": "rich_text_section",
            "elements": [
              {
                "type": "text",
                "text": "FWIW, my reaction to something mentioned in the latest FoC podcast ("
              },
              {
                "type": "link",
                "url": "https://futureofcoding.org/episodes/073"
              },
              {
                "type": "text",
                "text": "):\n\nComputer Science isn’t about "
              },
              {
                "type": "text",
                "text": "programming",
                "style": {
                  "italic": true
                }
              },
              {
                "type": "text",
                "text": ". Computer Science is about mapping computational thinking into the digital domain and discovering problems in an ad-hoc manner, then fixing the problems to make the mapping work on reprogrammable electronic machines.\n\n"
              },
              {
                "type": "link",
                "url": "https://programmingsimplicity.substack.com/p/computational-thinking-run-amok?r=1egdky"
              }
            ]
