    "client_msg_id": "c189d5ec-3d40-4fd2-8b68-b67f3124e5f7",
    "text": "Good question <@U0378MDUG1Y>. Both, but in different ways. In one scenario, we need to be dealing with an organisation – even if it's a small one – and just a front for an individual. But this organisation needs to be eligible so you'll need to check the funding website linked from the doc linked above. If there's no organisation then we can contract an individual to Kendraio but then we still need a partner organisation in the US or Canada. But happy to talk about contracting as a parallel potential.",
    "team": "T5TCAFTA9",
    "thread_ts": "1729609057.531229",
    "parent_user_id": "U0768BNPTEY",
    "blocks": [
      {
        "type": "rich_text",
        "block_id": "LIpqu",
        "elements": [
          {
            "type": "rich_text_section",
            "elements": [
              {
                "type": "text",
                "text": "Good question "
              },
              {
                "type": "user",
                "user_id": "U0378MDUG1Y"
              },
              {
                "type": "text",
                "text": ". Both, but in different ways. In one scenario, we need to be dealing with an organisation – even if it's a small one – and just a front for an individual. But this organisation needs to be eligible so you'll need to check the funding website linked from the doc linked above. If there's no organisation then we can contract an individual to Kendraio but then we still need a partner organisation in the US or Canada. But happy to talk about contracting as a parallel potential."
              }
            ]
          }
        ]
      }
