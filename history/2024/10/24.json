  {
    "user": "UCUSW7WVD",
    "type": "message",
    "ts": "1729764874.366279",
    "client_msg_id": "f35cd989-8b47-4429-967d-17190c1d2762",
    "text": "But now this thread connects up for me with <https://merveilles.town/@akkartik/113289704043435985|a recent discussion on Mastodon> about what 'understanding' means, and where 'understanding' lies.\n\n&gt; Computer programs are complex systems so it is impossible to understand them just by reading them.\nIt is arguably also impossible to understand most programs today just by running them.",
    "team": "T5TCAFTA9",
    "thread_ts": "1729527253.637669",
    "parent_user_id": "U055V4HCHU7",
    "blocks": [
      {
        "type": "rich_text",
        "block_id": "LWOs3",
        "elements": [
          {
            "type": "rich_text_section",
            "elements": [
              {
                "type": "text",
                "text": "But now this thread connects up for me with "
              },
              {
                "type": "link",
                "url": "https://merveilles.town/@akkartik/113289704043435985",
                "text": "a recent discussion on Mastodon"
              },
              {
                "type": "text",
                "text": " about what 'understanding' means, and where 'understanding' lies.\n\n"
              }
            ]
          },
          {
            "type": "rich_text_quote",
            "elements": [
              {
                "type": "text",
                "text": "Computer programs are complex systems so it is impossible to understand them just by reading them."
              }
            ]
          },
          {
            "type": "rich_text_section",
            "elements": [
              {
                "type": "text",
                "text": "\nIt is arguably also impossible to understand most programs today just by running them."
              }
            ]
          }
        ]
      }
    ],
    "reactions": [
      {
        "name": "heavy_plus_sign",
        "users": [
          "UJBAJNFLK"
        ],
        "count": 1
      }
    ],
    "channel_name": "thinking-together",
    "channel_id": "C5T9GPWFL"
