              {
                "type": "link",
                "url": "https://akkartik.name/archives/foc/of-end-user-programming/1573942666.111300.html"
              },
              {
                "type": "text",
                "text": "\n\n"
              },
              {
                "type": "link",
                "url": "https://akkartik.name/archives/foc/of-logic-programming/1621430499.000300.html"
              },
              {
                "type": "text",
                "text": "\n\n"
              },
              {
                "type": "link",
                "url": "https://akkartik.name/archives/foc/of-music/1625731658.003200.html"
              },
              {
                "type": "text",
                "text": "\n\nThe history of "
              },
              {
                "type": "channel",
                "channel_id": "CC2JRGVLK"
              },
              {
                "type": "text",
                "text": " has a "
              },
