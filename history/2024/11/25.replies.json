    "text": "I did <https://akkartik.name/codelog.html|this> many years ago.",
    "team": "T5TCAFTA9",
    "thread_ts": "1732543398.418729",
    "parent_user_id": "U08294YLWJH",
    "blocks": [
      {
        "type": "rich_text",
        "block_id": "8WQlA",
        "elements": [
          {
            "type": "rich_text_section",
            "elements": [
              {
                "type": "text",
                "text": "I did "
              },
              {
                "type": "link",
                "url": "https://akkartik.name/codelog.html",
                "text": "this"
              },
              {
                "type": "text",
