                ]
              },
              {
                "type": "rich_text_section",
                "elements": [
                  {
                    "type": "text",
                    "text": "inside feature branch commits do not have any meaningful text except for the time of change;"
                  }
                ]
              },
              {
                "type": "rich_text_section",
                "elements": [
                  {
