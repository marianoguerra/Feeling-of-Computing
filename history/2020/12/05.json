    "text": "<https://johncarlosbaez.wordpress.com/2020/12/04/graph-transformation-theory-and-applications/|https://johncarlosbaez.wordpress.com/2020/12/04/graph-transformation-theory-and-applications/>",
    "user": "USH01JEDQ",
    "ts": "1607148052.311000",
