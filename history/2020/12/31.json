    "client_msg_id": "3616a5dd-cdc4-4a53-87bc-71623c34b8d2",
    "type": "message",
    "text": "Hey Sergii, I just checked out your creative code synthesis project and it looks pretty cool, some of the images are very beautiful. When you mentioned a human curator I wondered what would happen if you used genetic programming ideas to home in on interesting programs. Instead of one program being generated randomly from scratch, you could generate a grid of mutations of a program and the user could pick the one they like best, and then you create random mutations from that. Little by little the programs and the images they create should become more and more interesting.",
    "user": "U01GPM3BY4R",
    "ts": "1609416469.268800",
    "team": "T5TCAFTA9",
    "user_team": "T5TCAFTA9",
    "source_team": "T5TCAFTA9",
    "user_profile": {
      "avatar_hash": "37dd3248d4e1",
      "image_72": "https://avatars.slack-edge.com/2021-10-22/2659944513472_37dd3248d4e11b1be060_72.jpg",
      "first_name": "",
      "real_name": "Felipe Reigosa",
      "display_name": "Felipe Reigosa",
      "team": "T5TCAFTA9",
      "name": "felipereigosa",
      "is_restricted": false,
      "is_ultra_restricted": false
    },
    "blocks": [
      {
        "type": "rich_text",
        "block_id": "QpavI",
        "elements": [
          {
            "type": "rich_text_section",
            "elements": [
              {
                "type": "text",
                "text": "Hey Sergii, I just checked out your creative code synthesis project and it looks pretty cool, some of the images are very beautiful. When you mentioned a human curator I wondered what would happen if you used genetic programming ideas to home in on interesting programs. Instead of one program being generated randomly from scratch, you could generate a grid of mutations of a program and the user could pick the one they like best, and then you create random mutations from that. Little by little the programs and the images they create should become more and more interesting."
              }
            ]
          }
        ]
      }
    ],
