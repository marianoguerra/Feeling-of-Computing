              },
              {
                "type": "text",
                "text": "~/.xsh",
                "style": {
                  "code": true
                }
              },
              {
                "type": "text",
                "text": " and "
              },
              {
                "type": "text",
                "text": "~/.xiki",
                "style": {
                  "code": true
                }
              },
              {
                "type": "text",
                "text": " , both of which are created silently when you first run "
              },
              {
                "type": "text",
                "text": "xsh",
                "style": {
                  "code": true
                }
              },
              {
                "type": "text",
                "text": ". And you must remove the line appended to "
              },
              {
                "type": "text",
                "text": ".zshrc",
                "style": {
                  "code": true
                }
              },
              {
                "type": "text",
                "text": " (or its bash equivalent), which says "
              },
              {
                "type": "text",
                "text": "source ~/.xsh",
                "style": {
                  "code": true
                }
              },
              {
                "type": "text",
                "text": "."
              }
            ]
          }
        ]
