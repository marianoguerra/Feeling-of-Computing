    "client_msg_id": "4d13c6d9-d447-44db-a297-b010dc5facb5",
    "type": "message",
    "text": "<@U02U0AS3J49> there's a cycle detector so cyclical rules will be caught at compile time\n\nthey all are applied simulataneously, but there are some automatically generated features to help with waiting (such as `SqrlExecutionComplete` that depends on all of the rules finishing executintg)",
    "user": "U01S68SJH63",
    "ts": "1675793590.672189",
    "blocks": [
      {
        "type": "rich_text",
        "block_id": "bVh6",
        "elements": [
          {
            "type": "rich_text_section",
            "elements": [
              {
                "type": "user",
                "user_id": "U02U0AS3J49"
              },
              {
                "type": "text",
                "text": " there's a cycle detector so cyclical rules will be caught at compile time\n\nthey all are applied simulataneously, but there are some automatically generated features to help with waiting (such as "
              },
              {
                "type": "text",
                "text": "SqrlExecutionComplete",
                "style": {
                  "code": true
                }
              },
              {
                "type": "text",
                "text": " that depends on all of the rules finishing executintg)"
              }
            ]
          }
        ]
      }
