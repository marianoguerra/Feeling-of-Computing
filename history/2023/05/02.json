    "client_msg_id": "cd5098c8-4ad0-4708-9d68-0168b9535f51",
    "type": "message",
    "text": "Been thinking about the infra needed for human-machine teaming, I think a lot of knowledge from the field of business process management can be reimagined, just with powerful natural language capabilities.\n\n• Natural language becomes the API interface between humans and machines.\n• No need to formally describe the workflow. Just talk to it and let the LLM create/modify/delete these.\n• These workflows are essentially Turing-complete, distributed program where the job \"processors\" are people and bots. For eg: BPMN already supported branching, sequential processing, parallel processing etc.\n• Open-source Zapier-equivalent systems can be a good starting point for these.",
    "user": "U018S42NMMM",
    "ts": "1683017799.810649",
    "blocks": [
      {
        "type": "rich_text",
        "block_id": "gsU",
        "elements": [
          {
            "type": "rich_text_section",
            "elements": [
              {
                "type": "text",
                "text": "Been thinking about the infra needed for human-machine teaming, I think a lot of knowledge from the field of business process management can be reimagined, just with powerful natural language capabilities.\n\n"
              }
            ]
          },
          {
            "type": "rich_text_list",
            "elements": [
              {
                "type": "rich_text_section",
                "elements": [
                  {
                    "type": "text",
                    "text": "Natural language becomes the API interface between humans and machines."
                  }
                ]
              },
              {
                "type": "rich_text_section",
                "elements": [
                  {
                    "type": "text",
                    "text": "No need to formally describe the workflow. Just talk to it and let the LLM create/modify/delete these."
                  }
                ]
              },
              {
                "type": "rich_text_section",
                "elements": [
                  {
                    "type": "text",
                    "text": "These workflows are essentially Turing-complete, distributed program where the job \"processors\" are people and bots. For eg: BPMN already supported branching, sequential processing, parallel processing etc."
                  }
                ]
              },
              {
                "type": "rich_text_section",
                "elements": [
                  {
                    "type": "text",
                    "text": "Open-source Zapier-equivalent systems can be a good starting point for these."
                  }
                ]
              }
            ],
