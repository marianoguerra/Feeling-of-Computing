  {
    "client_msg_id": "3c607c99-6368-4187-9d98-6acaa6568607",
    "type": "message",
    "text": "Parsing is everyone's problem. The user needs a fairly accurate mental model of how the parser works to be able to read or write their code. They have to parse it mentally to read it, and code is read more often than it's written.",
    "user": "U016VUZGUUQ",
