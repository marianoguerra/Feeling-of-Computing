    "attachments": [
      {
        "service_name": "esoteric.codes",
        "title": "Interview with 100 Rabbits",
        "title_link": "https://esoteric.codes/blog/100-rabbits",
        "text": "Perhaps best known for their esoteric livecoding language ORCΛ, 100 Rabbits (Rekka and Devine) have a creative practice that seamlessly crosses from the esoteric to the practical. Living on a boat and relying primarily on solar energy, they create their own tools to avoid the impracticalities and wastefulness of commercial software. Their work has a rare coherence of thought and design that bridges art, code, and life.",
        "fallback": "esoteric.codes: Interview with 100 Rabbits",
        "image_url": "https://esoteric.codes/uploads/54545341-a443-483a-b6a7-03ca62e89bb6/100rabbits_front.png",
        "image_width": 398,
        "image_height": 250,
        "ts": 1612444200,
        "from_url": "https://esoteric.codes/blog/100-rabbits",
        "image_bytes": 51877,
        "service_icon": "https://esoteric.codes/apple-touch-icon-57x57.png",
        "id": 1,
        "original_url": "https://esoteric.codes/blog/100-rabbits"
      }
    ],
    "blocks": [
      {
        "type": "rich_text",
        "block_id": "G1mHF",
        "elements": [
          {
            "type": "rich_text_section",
            "elements": [
              {
                "type": "text",
                "text": "I always enjoy reading interviews with 100 Rabbits. Their perspective on technology is astoundingly pragmatic, and yet very opinionated at the same time. \n\nIn my dreams, one possible future of programming is that more people can talk about their (technology-driven) projects like that, as if technology didn’t matter that much, wasn't such a big deal and just a tool and you didn’t have to spend years learning how to put together several programming languages on your own to finally feel the freedom of being able to build anything you want.\n"
              },
              {
                "type": "link",
                "url": "https://esoteric.codes/blog/100-rabbits",
                "text": "https://esoteric.codes/blog/100-rabbits"
