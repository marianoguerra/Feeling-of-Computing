    "attachments": [
      {
        "from_url": "https://observablehq.com/@tomlarkworthy/switch-dataflow",
        "title": "How to switch Dataflow on Observable",
        "title_link": "https://observablehq.com/@tomlarkworthy/switch-dataflow",
        "text": "In this series, I will explore programming techniques for the notebook platform Observable. Today I am looking at how to direct a reactive Dataflow stream to one-of-n downstream cells. This article assumes you are familiar with Observable's non-linear reactive program flow already. Sometimes we want control the dataflow with logic. If we have a cell called data streaming values, we might like to direct those updates to either cell_1 or cell_2. You can programatically trigger dataflow by calling dispatchEven",
        "image_url": "https://static.observableusercontent.com/thumbnail/6aaa0774fdd549ba56faf1a39cce0298c672175274f94a0e82bafa321c43cded.jpg",
        "image_width": 400,
        "image_height": 250,
        "image_bytes": 26826,
        "fallback": "How to switch Dataflow on Observable",
        "service_icon": "https://observablehq.com/favicon-512.png",
        "service_name": "observablehq.com",
        "id": 1,
        "original_url": "https://observablehq.com/@tomlarkworthy/switch-dataflow"
      }
    ],
