    "root": {
      "client_msg_id": "bc25b507-b176-457d-8668-c56d59687cba",
      "type": "message",
      "text": "New video about my browser for FoC archives (5 minutes): <https://archive.org/details/akkartik-mu-2021-08-15>\n\nYou can try it out by downloading two files (and installing Qemu):\n• <http://akkartik.name/mu/foc-data-20210814.img.gz>\n• <http://akkartik.name/mu/mu-browser-20210815.img.gz>\nThen:\n```gunzip foc-data-20210814.img.gz\ngunzip mu-browser-20210815.img.gz\nqemu-system-i386 -m 2G -hda mu-browser-20210815.img -hdb foc-data-20210814.img```\nMain project page: <https://github.com/akkartik/mu>",
      "user": "UCUSW7WVD",
      "ts": "1629094849.052400",
      "team": "T5TCAFTA9",
      "edited": {
        "user": "UCUSW7WVD",
        "ts": "1629095023.000000"
      },
      "blocks": [
        {
          "type": "rich_text",
          "block_id": "8CzCD",
          "elements": [
            {
              "type": "rich_text_section",
              "elements": [
                {
                  "type": "text",
                  "text": "New video about my browser for FoC archives (5 minutes): "
                },
                {
                  "type": "link",
                  "url": "https://archive.org/details/akkartik-mu-2021-08-15"
                },
                {
                  "type": "text",
                  "text": "\n\nYou can try it out by downloading two files (and installing Qemu):\n"
                }
              ]
            },
            {
              "type": "rich_text_list",
              "elements": [
                {
                  "type": "rich_text_section",
                  "elements": [
                    {
                      "type": "link",
                      "url": "http://akkartik.name/mu/foc-data-20210814.img.gz"
                    }
                  ]
                },
                {
                  "type": "rich_text_section",
                  "elements": [
                    {
                      "type": "link",
                      "url": "http://akkartik.name/mu/mu-browser-20210815.img.gz"
                    }
                  ]
                }
              ],
              "style": "bullet",
              "indent": 0,
              "border": 0
            },
            {
              "type": "rich_text_section",
              "elements": [
                {
                  "type": "text",
                  "text": "Then:\n"
                }
              ]
            },
            {
              "type": "rich_text_preformatted",
              "elements": [
                {
                  "type": "text",
                  "text": "gunzip foc-data-20210814.img.gz\ngunzip mu-browser-20210815.img.gz\nqemu-system-i386 -m 2G -hda mu-browser-20210815.img -hdb foc-data-20210814.img"
                }
              ]
            },
            {
              "type": "rich_text_section",
              "elements": [
                {
                  "type": "text",
                  "text": "\nMain project page: "
                },
                {
                  "type": "link",
                  "url": "https://github.com/akkartik/mu"
                }
              ]
            }
          ]
        }
      ],
