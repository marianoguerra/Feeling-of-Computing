    "upload": false,
    "user": "UCUSW7WVD",
    "ts": "1630383330.016300",
    "blocks": [
      {
        "type": "rich_text",
        "block_id": "gChIX",
        "elements": [
          {
            "type": "rich_text_section",
            "elements": [
              {
                "type": "text",
                "text": "The Mu computer's FoC archive browser now renders most Unicode. See the before/after images below.\n\nI'm loading 140KB of Unicode glyphs from its system font. Unicode blocks now supported: latin, greek, cyrillic, armenian, hebrew, arabic, syriac, thaana, n'ko, indian (ISCII), sinhala, thai, lao, tibetan, myanmar, georgian (< U+1100)\n\nWhile this is useful in a mostly-English corpus, there are caveats for more intensive use cases:\n"
              }
            ]
          },
          {
            "type": "rich_text_list",
            "elements": [
              {
                "type": "rich_text_section",
                "elements": [
                  {
                    "type": "text",
                    "text": "No support for "
                  },
                  {
                    "type": "link",
                    "url": "https://en.wikipedia.org/wiki/Combining_character",
                    "text": "combining characters"
                  },
                  {
                    "type": "text",
                    "text": " yet. This makes support for the other languages I know (Hindi and Tamil, which use "
                  },
                  {
                    "type": "link",
                    "url": "https://en.wikipedia.org/wiki/Devanagari#Vowel_diacritics",
                    "text": "matras",
                    "style": {
                      "italic": true
                    }
                  },
                  {
                    "type": "text",
                    "text": ") well-nigh useless."
                  }
                ]
              },
              {
                "type": "rich_text_section",
                "elements": [
                  {
                    "type": "link",
                    "url": "http://unifoundry.com/unifont/index.html",
                    "text": "GNU Unifont"
                  },
                  {
                    "type": "text",
                    "text": "'s glyphs for the non-Latin languages I know turn out to be quite spectacularly ugly."
                  }
                ]
              }
            ],
            "style": "bullet",
            "indent": 0,
            "border": 0
          }
        ]
      }
    ],
    "edited": {
