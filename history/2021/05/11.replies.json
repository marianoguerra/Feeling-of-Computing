      "ts": "1620718570.128800",
      "blocks": [
        {
          "type": "rich_text",
          "block_id": "lG=",
          "elements": [
            {
              "type": "rich_text_section",
              "elements": [
                {
                  "type": "text",
                  "text": "A program to turn a still image into a rotating animated GIF, with each frame rotated by n/16 turns, for previewing "
                },
                {
                  "type": "link",
                  "url": "https://en.wikipedia.org/wiki/Phenakistiscope",
                  "text": "phenakistiscope"
                },
                {
                  "type": "text",
                  "text": " design.\n\nVery niche app, but that's one of the points of Meemoo. I have to remind myself that it's still chugging along after all these years, and useful for these niche problems.\n\nLive: "
                },
                {
                  "type": "link",
                  "url": "https://app.meemoo.org/#gist/9aa9184a1589f1cfbfce376ab29fe6fc"
                },
                {
                  "type": "text",
                  "text": "\n(You have to increment the "
                },
                {
                  "type": "text",
                  "text": "frame",
                  "style": {
                    "code": true
                  }
                },
                {
                  "type": "text",
                  "text": " input manually from 0-15, and then press \"play\" or \"make gif\" in the \"animation\" box.)\nGIF in thread"
                }
              ]
            }
          ]
        }
      ],
