        "author_link": "https://www.youtube.com/c/DesignLabUCSD",
        "video_html": "<iframe width=\"400\" height=\"225\" src=\"https://www.youtube.com/embed/blLhklI625s?feature=oembed&autoplay=1&iv_load_policy=3\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" allowfullscreen></iframe>",
        "video_html_width": 400,
        "video_html_height": 225,
        "fallback": "YouTube Video: Rethinking Software Design | Daniel Jackson | Design@Large",
        "thumb_url": "https://i.ytimg.com/vi/blLhklI625s/hqdefault.jpg",
