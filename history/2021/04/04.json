  {
    "client_msg_id": "340b3139-7cf6-4a2b-af56-ffa2a357b4d4",
    "type": "message",
    "text": "I enjoyed Toussaint's book, but also enjoyed Kofi Agawu's take on it - he talks about these diagrams as 'paper rhythms' in the pejorative, for example he discounts the process of rotating rhythms as meaningful, because that only makes sense on paper. His argument is that if you rotate a rhythm, you end up with a totally new rhythm, which is obvious if you dance to it, but not if you only look at it on paper.",
    "user": "URLP9FWR3",
    "ts": "1617565988.007300",
    "team": "T5TCAFTA9",
    "user_team": "T5TCAFTA9",
    "source_team": "T5TCAFTA9",
