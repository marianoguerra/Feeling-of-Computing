    "client_msg_id": "5fbaf40c-eea7-4ff9-8542-8877a5adef3a",
    "type": "message",
    "text": "Bernard Bel's writing on time setting in his Bol Processor system is really interesting, in that it comes from Indian classical music.. So _is_ focussed on time context in rhythmic cycles, rather treating beats as fixed units as with staff notation",
    "user": "URLP9FWR3",
    "ts": "1617716322.009600",
    "team": "T5TCAFTA9",
    "user_team": "T5TCAFTA9",
