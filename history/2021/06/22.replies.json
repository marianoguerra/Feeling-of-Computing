  {
    "client_msg_id": "bb6d9dda-7957-4124-9030-890a019717ba",
    "type": "message",
    "text": "The root of the problem is that rules in Prolog/Datalog don't _compose_. You can have two rulesets which terminate when run independently, but act non-deterministically (or fail to terminate) when combined.",
    "user": "UCGAK10LS",
    "ts": "1624435483.029300",
    "team": "T5TCAFTA9",
