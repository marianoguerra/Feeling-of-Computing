        "elements": [
          {
            "type": "rich_text_section",
            "elements": [
              {
                "type": "text",
                "text": "I'm working on a library for incremental computation that can handle loops/fixpoints/recursion, supports out-of-order inputs, will soon support automatic parallelization and whose api is focused on being a good backend for a language.\n\nThere's still a fair bit of work to go before it's useful, but there's enough working already to be worth reading - "
              },
              {
                "type": "link",
                "url": "https://github.com/jamii/dida"
              }
            ]
          }
        ]
      }
